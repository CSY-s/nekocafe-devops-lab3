{
  "title": "NekoCafe DevOps Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "QPS",
      "type": "timeseries",
      "targets": [{ "expr": "rate(http_requests_total[1m])" }],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "P99 Latency",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))" }],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(http_requests_total{status=~\"5..\"}[5m])" }],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total{pod=~\"nekocafe.*\"}[5m])" }],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    }
  ]
}
